{
    "name": "eslint-config-ironplate",
    "version": "2.4.0",
    "description": "Shareable ESLint configuration",
    "engines": {
        "node": ">=20"
    },
    "type": "module",
    "main": "index.js",
    "exports": {
        ".": "./index.js",
        "./node.js": "./node.js",
        "./react.js": "./react.js",
        "./typescript.js": "./typescript.js",
        "./node-typescript.js": "./node-typescript.js",
        "./react-typescript.js": "./react-typescript.js",
        "./package.json": "./package.json"
    },
    "scripts": {
        "eslint": "eslint .",
        "postinstall": "node ./scripts/postinstall.js",
        "postversion": "git push --follow-tags",
        "test:data": "npm run --prefix ./test/core test && npm run --prefix ./test/node test && npm run --prefix ./test/react test && npm run --prefix ./test/typescript test && npm run --prefix ./test/node-typescript test && npm run --prefix ./test/react-typescript test",
        "test": "npm run eslint && npm run test:data"
    },
    "peerDependencies": {
        "@eslint-react/eslint-plugin": "*",
        "@eslint/js": "*",
        "@stylistic/eslint-plugin": "*",
        "eslint": "*",
        "eslint-plugin-import-x": "*",
        "eslint-plugin-n": "*",
        "eslint-plugin-promise": "*",
        "eslint-plugin-react-hooks": "*",
        "eslint-plugin-react-refresh": "*",
        "eslint-plugin-unicorn": "*",
        "globals": "*",
        "typescript": "*",
        "typescript-eslint": "*"
    },
    "devDependencies": {
        "@eslint-react/eslint-plugin": "*",
        "eslint-plugin-react-hooks": "*",
        "eslint-plugin-react-refresh": "*",
        "typescript-eslint": "*"
    },
    "peerDependenciesMeta": {
        "@eslint-react/eslint-plugin": {
            "optional": true
        },
        "eslint-plugin-react-hooks": {
            "optional": true
        },
        "eslint-plugin-react-refresh": {
            "optional": true
        },
        "typescript": {
            "optional": true
        },
        "typescript-eslint": {
            "optional": true
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/webextensions/eslint-config-ironplate.git"
    },
    "keywords": [
        "eslint",
        "eslintconfig"
    ],
    "author": "Priyank Parashar",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/webextensions/eslint-config-ironplate/issues"
    },
    "homepage": "https://github.com/webextensions/eslint-config-ironplate#readme"
}
